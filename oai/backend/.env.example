# Copy to .env when running `cargo run` outside `task dev`.
DATABASE_URL=postgres://oai:oai_dev_password@localhost:5432/oai
SERVER_ADDRESS=0.0.0.0:3001
JWT_SECRET=dev-secret-change-in-prod
ROOT_ADMIN_PASSWORD=000000

# Local files via OpenDAL (same as `task dev`)
STORAGE_BACKEND=fs
STORAGE_FS_ROOT=./.data/storage

# Optional: seed OffloadMQ keys on first boot (or set in Settings → Server)
# OFFLOAD_MQ_URL=http://localhost:3069
# OFFLOAD_MQ_CLIENT_KEY=client_secret_key_123
# OFFLOAD_MQ_MGMT_TOKEN=this-is-for-testing-management-tokens
